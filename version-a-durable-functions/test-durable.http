### -------------------------------------------------------
### Scenario 1: Valid expense under $100 -> Auto-approved
### -------------------------------------------------------
POST http://localhost:7071/api/expenses/start
Content-Type: application/json

{
  "employee_name": "Rohan Surti",
  "employee_email": "rohan@example.com",
  "amount": 50,
  "category": "meals",
  "description": "Team lunch during project meeting",
  "manager_email": "manager@example.com"
}

### -------------------------------------------------------
### Scenario 2: Valid expense >= $100, manager approves
### Step 1: Start workflow and copy the instanceId
### -------------------------------------------------------
POST http://localhost:7071/api/expenses/start
Content-Type: application/json

{
  "employee_name": "Rohan Surti",
  "employee_email": "rohan@example.com",
  "amount": 250,
  "category": "software",
  "description": "Purchased licensed software tool",
  "manager_email": "manager@example.com"
}

### -------------------------------------------------------
### Scenario 2: Manager approves
### Replace YOUR_INSTANCE_ID below
### -------------------------------------------------------
POST http://localhost:7071/api/expenses/{instanceId}/decision
Content-Type: application/json

{
  "decision": "approve"
}

### -------------------------------------------------------
### Scenario 3: Valid expense >= $100, manager rejects
### Step 1: Start workflow and copy the instanceId
### -------------------------------------------------------
POST http://localhost:7071/api/expenses/start
Content-Type: application/json

{
  "employee_name": "Rohan Surti",
  "employee_email": "rohan@example.com",
  "amount": 300,
  "category": "equipment",
  "description": "Requested a new monitor",
  "manager_email": "manager@example.com"
}

### -------------------------------------------------------
### Scenario 3: Manager rejects
### Replace YOUR_INSTANCE_ID below
### -------------------------------------------------------
POST http://localhost:7071/api/expenses/{instanceId}/decision
Content-Type: application/json

{
  "decision": "reject"
}

### -------------------------------------------------------
### Scenario 4: Valid expense >= $100, no manager response
### -------------------------------------------------------
POST http://localhost:7071/api/expenses/start
Content-Type: application/json

{
  "employee_name": "Rohan Surti",
  "employee_email": "rohan@example.com",
  "amount": 175,
  "category": "travel",
  "description": "Taxi reimbursement for client visit",
  "manager_email": "manager@example.com"
}

### -------------------------------------------------------
### Scenario 5: Missing required fields -> Validation error
### -------------------------------------------------------
POST http://localhost:7071/api/expenses/start
Content-Type: application/json

{
  "employee_name": "Rohan Surti",
  "employee_email": "rohan@example.com",
  "amount": 120,
  "category": "travel"
}

### -------------------------------------------------------
### Scenario 6: Invalid category -> Validation error
### -------------------------------------------------------
POST http://localhost:7071/api/expenses/start
Content-Type: application/json

{
  "employee_name": "Rohan Surti",
  "employee_email": "rohan@example.com",
  "amount": 120,
  "category": "gaming",
  "description": "Bought an unsupported category item",
  "manager_email": "manager@example.com"
}